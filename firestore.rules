rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(userEmail())) &&
        get(/databases/$(database)/documents/users/$(userEmail())).data.role == 'admin';
    }

    function isOrderOwner() {
      return isSignedIn() &&
        (resource.data.userEmail == userEmail() || (request.resource != null && request.resource.data.userEmail == userEmail()));
    }

    match /menuItems/{document=**} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{document=**} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      // Development fallback: permit reads until July 24, 2026.
      allow read: if request.time < timestamp.date(2026, 7, 24);
    }
  }
}
